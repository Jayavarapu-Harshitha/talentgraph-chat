# ── Supabase ────────────────────────────────────────────────
# Project URL + anon key (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key   # kept for completeness; not required by the current flow

# Service-role key (Project Settings → API → service_role). SERVER ONLY.
# Used by all API routes to read/write the `interviews` table (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── LLM providers (server-side only — never exposed to the browser) ──────────
# The chat route tries providers in order and only errors if ALL fail:
#   1) Groq        (PRIMARY  — dedicated per-key free tier, reliable & fast)
#   2) OpenRouter  (FALLBACK — free models share a global pool, frequent 429)
#   3) Gemini      (LAST     — many accounts have free-tier limit 0)
#
# ── 1) Groq (RECOMMENDED primary — reliable free tier, no card needed) ───────
# Create a free key at https://console.groq.com/keys
# Free tier (llama-3.3-70b-versatile): ~30 req/min, ~1,000 req/day — a DEDICATED
# lane that does not random-429 like shared pools. This keeps chat stable for free.
GROQ_API_KEY=
# Comma-separated; first is primary. llama-3.1-8b-instant has an even higher daily cap.
GROQ_MODEL=llama-3.3-70b-versatile,llama-3.1-8b-instant

# ── 2) OpenRouter (fallback) ─────────────────────────────────────────────────
# Create a key at https://openrouter.ai/keys . Used only if Groq is unavailable.
# Free models share a global pool and frequently 429 with no credit balance.
# Set to a paid slug (e.g. anthropic/claude-sonnet-4.6) if you add OpenRouter credit.
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free,qwen/qwen3-next-80b-a3b-instruct:free,google/gemini-2.0-flash-exp:free

# ── 3) Google Gemini (optional tail) ─────────────────────────────────────────
# https://aistudio.google.com/apikey — NOTE: many accounts/regions get free-tier
# limit 0 (needs Cloud billing for any quota), so this is best-effort only.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional: shown in OpenRouter dashboard analytics
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=TalentGraph

# ── Admin dashboard ─────────────────────────────────────────
ADMIN_PASSWORD=research2026
