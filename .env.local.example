# ── Supabase ────────────────────────────────────────────────
# Project URL + anon key (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key   # kept for completeness; not required by the current flow

# Service-role key (Project Settings → API → service_role). SERVER ONLY.
# Used by all API routes to read/write the `interviews` table (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── LLM providers (server-side only — never exposed to the browser) ──────────
# The chat route tries providers in order and only errors if ALL fail:
#   1) Google Gemini free tier (PRIMARY — dedicated per-key quota, no shared pool)
#   2) OpenRouter free models (FALLBACK chain)
#
# ── 1) Google Gemini (RECOMMENDED primary — reliable free tier) ──────────────
# Create a free key at https://aistudio.google.com/apikey (no billing needed).
# Free tier: ~1,500 requests/day, 15/min on gemini-2.0-flash — a dedicated lane
# that does NOT random-429 like shared free pools. This is what keeps chat stable.
GEMINI_API_KEY=
# Comma-separated; first is primary. Alternatives: gemini-2.5-flash, gemini-2.0-flash-lite
GEMINI_MODEL=gemini-2.0-flash

# ── 2) OpenRouter (fallback) ─────────────────────────────────────────────────
# Create a key at https://openrouter.ai/keys . Used only if Gemini is unavailable.
# NOTE: free models share a global pool and frequently 429 with no credit balance,
# which is exactly why Gemini is the primary above. Comma-separated fallback chain;
# set to a paid slug (e.g. anthropic/claude-sonnet-4.6) if you add OpenRouter credit.
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free,qwen/qwen3-next-80b-a3b-instruct:free,google/gemini-2.0-flash-exp:free

# Optional: shown in OpenRouter dashboard analytics
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=TalentGraph

# ── Admin dashboard ─────────────────────────────────────────
ADMIN_PASSWORD=research2026
