# ── Supabase ────────────────────────────────────────────────
# Project URL + anon key (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key   # kept for completeness; not required by the current flow

# Service-role key (Project Settings → API → service_role). SERVER ONLY.
# Used by all API routes to read/write the `interviews` table (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── OpenRouter (Claude/DeepSeek/etc.) ───────────────────────
# Create a key at https://openrouter.ai/keys . SERVER ONLY — never exposed to the browser.
OPENROUTER_API_KEY=sk-or-v1-...

# Model used by Sri. Default is a FREE OpenRouter model.
# NOTE: free models share a global pool and frequently return HTTP 429 when an
# account has no credit balance. Adding even a small OpenRouter balance raises the
# daily cap (to ~1000/day) and largely avoids 429s; it also unlocks paid models
# such as anthropic/claude-sonnet-4.6 or deepseek/deepseek-chat-v3-0324.
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Optional: shown in OpenRouter dashboard analytics
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=TalentGraph

# ── Admin dashboard ─────────────────────────────────────────
ADMIN_PASSWORD=research2026
